{
  "name": "@ozo/litespec-cli",
  "version": "2.0.0",
  "type": "module",
  "description": "轻量级规范驱动开发 (SDD) CLI 工具，支持多 AI IDE 集成",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/inier/litespec-cli"
  },
  "homepage": "https://github.com/inier/litespec-cli#readme",
  "keywords": [
    "sdd",
    "spec-driven-development",
    "ai-coding",
    "cursor",
    "trae",
    "qoder",
    "claude-code",
    "cli",
    "workflow",
    "bun"
  ],
  "bin": {
    "litespec": "./cli.js"
  },
  "files": [
    "src",
    "dist",
    "cli.js",
    "README.md"
  ],
  "scripts": {
    "litespec": "bun run src/cli.ts",
    "test": "bun test",
    "build": "bun build src/cli.ts --compile --outfile dist/litespec",
    "build:linux-x64": "bun build src/cli.ts --compile --target=bun-linux-x64 --outfile dist/litespec-linux-x64",
    "build:linux-arm64": "bun build src/cli.ts --compile --target=bun-linux-arm64 --outfile dist/litespec-linux-arm64",
    "build:macos-x64": "bun build src/cli.ts --compile --target=bun-darwin-x64 --outfile dist/litespec-macos-x64",
    "build:macos-arm64": "bun build src/cli.ts --compile --target=bun-darwin-arm64 --outfile dist/litespec-macos-arm64",
    "build:win-x64": "bun build src/cli.ts --compile --target=bun-windows-x64 --outfile dist/litespec-win-x64.exe",
    "build:all": "bun build src/cli.ts --compile --target=bun-linux-x64 --outfile dist/litespec-linux-x64 && bun build src/cli.ts --compile --target=bun-linux-arm64 --outfile dist/litespec-linux-arm64 && bun build src/cli.ts --compile --target=bun-darwin-x64 --outfile dist/litespec-macos-x64 && bun build src/cli.ts --compile --target=bun-darwin-arm64 --outfile dist/litespec-macos-arm64 && bun build src/cli.ts --compile --target=bun-windows-x64 --outfile dist/litespec-win-x64.exe"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "bun-types": "latest"
  }
}
