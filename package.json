{
  "name": "@ozo/litespec-cli",
  "version": "2.0.0",
  "type": "module",
  "description": "轻量级规范驱动开发 (SDD) CLI 工具，支持多 AI IDE 集成",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/inier/litespec-cli"
  },
  "homepage": "https://github.com/inier/litespec-cli#readme",
  "keywords": [
    "sdd",
    "spec-driven-development",
    "ai-coding",
    "cursor",
    "trae",
    "qoder",
    "claude-code",
    "cli",
    "workflow",
    "bun"
  ],
  "bin": {
    "litespec": "./cli.js"
  },
  "files": [
    "src",
    "dist",
    "cli.js",
    "README.md"
  ],
  "scripts": {
    "litespec": "bun run src/cli.ts",
    "test": "bun test",
    "build": "bun build src/cli.ts --compile --outfile dist/litespec",
    "build:remote": "bun run scripts/build-remote.js",
    "download:artifacts": "bash scripts/download-artifacts.sh",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "bun-types": "latest"
  }
}
